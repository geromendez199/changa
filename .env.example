# WHY: Document every runtime environment variable used by the SPA and how to source it safely.
# CHANGED: YYYY-MM-DD

# Required in local and production.
# Purpose: Base URL for your Supabase project so the SPA can reach Auth and PostgREST.
# Where to get it: Supabase Dashboard -> Project Settings -> API -> Project URL.
# Local vs production: Different per Supabase project/environment.
VITE_SUPABASE_URL=

# Required in local and production.
# Purpose: Public anon key used by the browser client for authenticated and RLS-protected access.
# Where to get it: Supabase Dashboard -> Project Settings -> API -> anon public key.
# Local vs production: Different per Supabase project/environment. Never replace this with service_role.
VITE_SUPABASE_ANON_KEY=

# E2E runtime variables for Playwright.
# If PLAYWRIGHT_BASE_URL/BASE_URL are not set, Playwright starts local Vite on http://127.0.0.1:4173.
PLAYWRIGHT_BASE_URL=
BASE_URL=
TEST_EMAIL=
TEST_PASSWORD=
# Optional second actor (provider). If omitted, TEST_EMAIL / TEST_PASSWORD are reused.
TEST_PROVIDER_EMAIL=
TEST_PROVIDER_PASSWORD=

# Force global-setup to fail if auth credentials/config are missing.
# Set to 1 for final authenticated validation runs.
REQUIRE_AUTH_CREDENTIALS=0

# Optional: Sentry error tracking and performance monitoring.
# Purpose: Capture errors, stack traces, and session replays in production.
# Where to get it: Create project on sentry.io, copy DSN from Project Settings -> Client Keys (DSN).
# Local vs production: Use separate Sentry projects for dev/staging/prod; omit in local dev.
VITE_SENTRY_DSN=

# Optional: PostHog product analytics and feature flags.
# Purpose: Track user behavior, pageviews, custom events, identify users.
# Where to get it: Create account on posthog.com, copy API key from Project Settings -> API Keys.
# Local vs production: Use same key for all environments or separate projects.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional: Plausible Analytics (privacy-focused alternative to Google Analytics).
# Purpose: Track pageviews and basic user sessions (no cookies, no tracking).
# Where to get it: Create account on plausible.io and add domain. Key not needed (script-based).
# Local vs production: Only enable in production with real domain on plausible.io.
VITE_PLAUSIBLE_DOMAIN=

# Server-side only (never exposed to browser).
# Purpose: Generate dynamic sitemaps at build time from Supabase.
# Where to get it: Supabase Dashboard -> Project Settings -> API -> Service Role Secret.
# Warning: This is a privileged key. Never commit it; only set in Vercel env vars during build.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side only (used by sitemap generation).
# Purpose: Set the canonical base URL for sitemaps and robots.txt.
# Local vs production: Should match your domain (https://www.changa.blog in production).
SITE_URL=https://www.changa.blog
