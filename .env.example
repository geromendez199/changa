# Environment Variables — changa app
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# ─── Supabase ──────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ↑ These are EXPO_PUBLIC_ so they are bundled into the client JS.
# Using the ANON key here is safe — Supabase RLS enforces access control.
# NEVER expose the service_role key in client code.

# ─── Optional: Error monitoring (Sentry) ───────────────────────────────────
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy

# ─── How to set in Vercel ──────────────────────────────────────────────────
# Vercel dashboard → Your project → Settings → Environment Variables
# Add EXPO_PUBLIC_SUPABASE_URL and EXPO_PUBLIC_SUPABASE_ANON_KEY
# Then Redeploy.
